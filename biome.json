{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": [
      "src/**",
      "test/**",
      "scripts/**",
      "web/app/**",
      "web/components/**",
      "web/content/**",
      "web/lib/**",
      "web/scripts/**",
      "web/test/**",
      "web/*.json",
      "web/*.ts",
      "web/*.tsx",
      "web/*.mjs",
      "web/*.md",
      "examples/**",
      "!!examples/**/.next",
      "!!examples/**/playwright-report",
      "!!examples/**/test-results",
      "!!examples/**/blob-report",
      "!!examples/**/dist",
      "!!examples/**/build",
      "!!examples/**/out",
      "*.json",
      "*.ts",
      "*.md"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  }
}
